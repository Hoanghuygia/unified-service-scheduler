generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

enum HoldStatus {
  ACTIVE
  EXPIRED
  CONVERTED
}

model Technician {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  email        String        @unique
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ServiceBay {
  id           String        @id @default(uuid())
  name         String
  dealershipId String
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ServiceType {
  id               String            @id @default(uuid())
  name             String
  durationMinutes  Int
  appointments     Appointment[]
  appointmentHolds AppointmentHold[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Appointment {
  id              String            @id @default(uuid())
  vehicleId       String
  dealershipId    String
  desiredTime     DateTime
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(BOOKED)
  serviceTypeId   String
  technicianId    String?
  serviceBayId    String?
  appointmentHold AppointmentHold?
  serviceType     ServiceType       @relation(fields: [serviceTypeId], references: [id])
  technician      Technician?       @relation(fields: [technicianId], references: [id])
  serviceBay      ServiceBay?       @relation(fields: [serviceBayId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([dealershipId, startTime])
  @@index([vehicleId])
}

model AppointmentHold {
  id            String       @id @default(uuid())
  vehicleId     String
  dealershipId  String
  desiredTime   DateTime
  expiresAt     DateTime
  status        HoldStatus   @default(ACTIVE)
  serviceTypeId String
  appointmentId String?      @unique
  serviceType   ServiceType  @relation(fields: [serviceTypeId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([dealershipId, desiredTime])
  @@index([vehicleId])
}
