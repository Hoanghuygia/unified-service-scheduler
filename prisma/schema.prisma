generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  CONVERTED
}

model Dealership {
  id           String                          @id @default(uuid())
  name         String
  serviceBays  ServiceBay[]
  appointments Appointment[]
  reservations Reservation[]
  createdAt    DateTime                        @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime                        @updatedAt @db.Timestamptz(3)
}

model Technician {
  id           String                          @id @default(uuid())
  firstName    String
  lastName     String
  email        String                          @unique
  appointments Appointment[]
  reservations Reservation[]
  createdAt    DateTime                        @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime                        @updatedAt @db.Timestamptz(3)
}

model ServiceBay {
  id           String                          @id @default(uuid())
  name         String
  dealershipId String
  dealership   Dealership                      @relation(fields: [dealershipId], references: [id])
  appointments Appointment[]
  reservations Reservation[]
  createdAt    DateTime                        @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime                        @updatedAt @db.Timestamptz(3)

  @@index([dealershipId])
}

model ServiceType {
  id                      String                @id @default(uuid())
  name                    String
  durationMinutes         Int
  appointmentServiceTypes AppointmentServiceType[]
  reservationServiceTypes ReservationServiceType[]
  createdAt               DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt               DateTime              @updatedAt @db.Timestamptz(3)
}

model Appointment {
  id                   String                   @id @default(uuid())
  vehicleId            String
  startTime            DateTime                 @db.Timestamptz(3)
  endTime              DateTime                 @db.Timestamptz(3)
  totalDurationMinutes Int
  status               AppointmentStatus        @default(BOOKED)
  reservation          Reservation?
  serviceTypes         AppointmentServiceType[]

  dealershipId         String
  dealership           Dealership               @relation(fields: [dealershipId], references: [id])
  technicianId         String?
  technician           Technician?              @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  serviceBayId         String?
  serviceBay           ServiceBay?              @relation(fields: [serviceBayId], references: [id], onDelete: SetNull)

  createdAt            DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                 @updatedAt @db.Timestamptz(3)

  @@index([dealershipId, startTime])
  @@index([vehicleId])
  @@index([technicianId, startTime, endTime])
  @@index([serviceBayId, startTime, endTime])
}

model Reservation {
  id                   String                   @id @default(uuid())
  vehicleId            String
  desiredTime          DateTime                 @db.Timestamptz(3)
  startTime            DateTime                 @db.Timestamptz(3)
  endTime              DateTime                 @db.Timestamptz(3)
  expiresAt            DateTime                 @db.Timestamptz(3)
  totalDurationMinutes Int
  status               ReservationStatus        @default(ACTIVE)
  serviceTypes         ReservationServiceType[]

  dealershipId         String
  dealership           Dealership               @relation(fields: [dealershipId], references: [id])
  technicianId         String?
  technician           Technician?              @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  serviceBayId         String?
  serviceBay           ServiceBay?              @relation(fields: [serviceBayId], references: [id], onDelete: SetNull)
  appointmentId        String?                  @unique
  appointment          Appointment?             @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  createdAt            DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime                 @updatedAt @db.Timestamptz(3)

  @@index([dealershipId, startTime])
  @@index([vehicleId])
  @@index([technicianId, startTime, endTime])
  @@index([serviceBayId, startTime, endTime])
  @@index([expiresAt])
}

model AppointmentServiceType {
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now()) @db.Timestamptz(3)

  @@id([appointmentId, serviceTypeId])
  @@index([serviceTypeId])
}

model ReservationServiceType {
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  serviceTypeId String
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now()) @db.Timestamptz(3)

  @@id([reservationId, serviceTypeId])
  @@index([serviceTypeId])
}
